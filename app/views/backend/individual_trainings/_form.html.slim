= simple_form_for(@individual_training, url: backend_trainer_individual_trainings_path) do |f|
  = errors_for(@individual_training)
  .row
    - if current_client
      .col-md-6
        #stripe_ind_error.alert.alert-danger style="display:none"
        .panel.panel-success
          .panel-heading Dane do płatności
          .panel-body
            label Dane karty
            #card-element-training style="padding: 8px; border: 1px solid #ccc; border-radius: 4px;"
    .col-md-6
      label for='datepicker'* Data treningu
      = f.text_field :date_of_training, as: :date, class: 'datepicker', placeholder: 'Kliknij'
      label for='input_starttime'* Godzina rozpoczęcia
      = f.text_field :start_on, class: 'timepicker', required: true, id: 'input_starttime', placeholder: 'Kliknij'
      = f.input :training_cost_id, required: true, label: "Czas trwania", collection: @training_costs.map { |tc| [tc.full_duration, tc.id] }, prompt: 'Wybierz czas trwania treningu'
      = f.input :trainer_id, as: :hidden, input_html: { value: @trainer.id }
      = f.input :client_id, as: :hidden, input_html: { value: @client.id }
      = f.button :submit, class: "btn btn-primary btn-block"

javascript:
  jQuery(function() {
    var cardEl = document.getElementById('card-element-training');
    if (!cardEl) return;

    var stripe = Stripe($('meta[name="stripe-key"]').attr('content'));
    var elements = stripe.elements();
    var card = elements.create('card', {
      style: {
        base: { fontSize: '16px', color: '#424770' },
        invalid: { color: '#9e2146' }
      }
    });
    card.mount('#card-element-training');

    card.on('change', function(event) {
      if (event.error) {
        $('#stripe_ind_error').text(event.error.message).show();
      } else {
        $('#stripe_ind_error').hide();
      }
    });

    $('#new_individual_training').submit(function(e) {
      e.preventDefault();
      $('input[type=submit]').attr('disabled', true);
      stripe.createToken(card).then(function(result) {
        if (result.error) {
          $('#stripe_ind_error').text(result.error.message).show();
          $('input[type=submit]').attr('disabled', false);
        } else {
          $('#new_individual_training').append($('<input type="hidden" name="stripeToken" />').val(result.token.id));
          $('#new_individual_training')[0].submit();
        }
      });
    });
  });
